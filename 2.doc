------version 1------


class VocabParallelCrossEntropy(torch.autograd.Function):
    @staticmethod
    def forward(ctx, vocab_parallel_logits, targets, vocab_start, vocab_end):
        local_max = vocab_parallel_logits.max(dim=-1, keepdim=True).values
        dist.all_reduce(local_max, op=dist.ReduceOp.MAX)
        global_max = local_max
        
        logits_minus_max = vocab_parallel_logits - global_max
        exp_logits = torch.exp(logits_minus_max)
        local_sum_exp = exp_logits.sum(dim=-1, keepdim=True)
        dist.all_reduce(local_sum_exp, op=dist.ReduceOp.SUM)
        global_sum_exp = local_sum_exp
        
        target_mask = (targets >= vocab_start) & (targets < vocab_end)
        target_local = (targets - vocab_start).clamp(min=0, max=vocab_parallel_logits.size(-1) - 1)
        
        local_target_logits = torch.gather(vocab_parallel_logits, dim=-1, index=target_local.unsqueeze(-1))
        local_target_logits.masked_fill_(~target_mask.unsqueeze(-1), 0.0)
        dist.all_reduce(local_target_logits, op=dist.ReduceOp.SUM)
        global_target_logit = local_target_logits
        
        loss = torch.log(global_sum_exp) - (global_target_logit - global_max)
        probs = exp_logits / global_sum_exp
        ctx.save_for_backward(probs, target_mask, target_local)
        return loss.mean()

    @staticmethod
    def backward(ctx, grad_output):
        probs, target_mask, target_local = ctx.saved_tensors
        grad_logits = probs.clone()
        grad_logits.scatter_add_(dim=-1, index=target_local.unsqueeze(-1), 
                                 src=-1.0 * target_mask.unsqueeze(-1).float())
        
        grad_logits.mul_(grad_output / probs.size(0))
        return grad_logits, None, None, None

def vocab_parallel_cross_entropy(logits, targets, vocab_start, vocab_end):
    local_logits = logits.to_local() if isinstance(logits, DTensor) else logits
    if local_logits.dim() == 3:
        local_logits = local_logits.view(-1, local_logits.size(-1))
    if targets.dim() == 2:
        targets = targets.view(-1)
    return VocabParallelCrossEntropy.apply(local_logits, targets, vocab_start, vocab_end)


------version 2------

# =============================================================================
# Vocab-Parallel Cross Entropy
# =============================================================================

class VocabParallelCrossEntropy(torch.autograd.Function):
    @staticmethod
    def forward(ctx, vocab_parallel_logits, targets, vocab_start, vocab_end):
        local_max = vocab_parallel_logits.max(dim=-1, keepdim=True).values
        dist.all_reduce(local_max, op=dist.ReduceOp.MAX)
        global_max = local_max
        
        logits_minus_max = vocab_parallel_logits - global_max
        exp_logits = torch.exp(logits_minus_max)
        local_sum_exp = exp_logits.sum(dim=-1, keepdim=True)
        dist.all_reduce(local_sum_exp, op=dist.ReduceOp.SUM)
        global_sum_exp = local_sum_exp
        
        target_mask = (targets >= vocab_start) & (targets < vocab_end)
        target_local = (targets - vocab_start).clamp(min=0, max=vocab_parallel_logits.size(-1) - 1)
        
        local_target_logits = torch.gather(vocab_parallel_logits, dim=-1, index=target_local.unsqueeze(-1))
        local_target_logits.masked_fill_(~target_mask.unsqueeze(-1), 0.0)
        dist.all_reduce(local_target_logits, op=dist.ReduceOp.SUM)
        global_target_logit = local_target_logits
        
        loss = torch.log(global_sum_exp) - (global_target_logit - global_max)
        probs = exp_logits / global_sum_exp
        ctx.save_for_backward(probs, target_mask, target_local)
        return loss.mean()

    @staticmethod
    def backward(ctx, grad_output):
        probs, target_mask, target_local = ctx.saved_tensors
        
        # In-place modify probs to save memory (it is not used elsewhere after this)
        # Gradient is (probs - 1.0) for the target class, and probs otherwise.
        probs.scatter_add_(dim=-1, index=target_local.unsqueeze(-1), 
                          src=-1.0 * target_mask.unsqueeze(-1).float())
        
        # Scale by grad_output and normalize by batch size
        probs.mul_(grad_output / probs.size(0))
        return probs, None, None, None

def vocab_parallel_cross_entropy(logits, targets, vocab_start, vocab_end):
    local_logits = logits.to_local() if isinstance(logits, DTensor) else logits
    if local_logits.dim() == 3:
        local_logits = local_logits.view(-1, local_logits.size(-1))
    if targets.dim() == 2:
        targets = targets.view(-1)
    return VocabParallelCrossEntropy.apply(local_logits, targets, vocab_start, vocab_end)

----version 3----

Algorithm: Distributed Parallel Cross-Entropy (loss_parallel)
Input: Logit shards (x_local), Target class index (target)

1. Compute local_max = max(x_local)
2. Sync global_max = All-Reduce-Max(local_max)

3. Compute local_sum_exp = sum(exp(x_local - global_max))
4. Sync global_sum_exp = All-Reduce-Sum(local_sum_exp)

5. If target index is in current GPU shard:
       target_logit = x[target]
   Else:
       target_logit = 0
6. Sync global_target_logit = All-Reduce-Sum(target_logit)

7. Compute Loss = -(global_target_logit - global_max) + log(global_sum_exp)
8. Return Loss
    